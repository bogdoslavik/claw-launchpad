{
  "name": "claw-launchpad",
  "private": true,
  "type": "module",
  "packageManager": "npm@11.12.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "db:generate": "prisma generate",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:up": "docker compose -f docker-compose.db.yml up -d",
    "dev:api": "npm run dev --workspace @launchpad/api",
    "dev:web": "npm run dev --workspace @launchpad/web",
    "dev:worker": "npm run dev --workspace @launchpad/worker",
    "postinstall": "prisma generate",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "npm run typecheck --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "dotenv": "^17.2.3",
    "jsdom": "^27.0.1",
    "prisma": "^7.7.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}

NODE_ENV=development
HOST=0.0.0.0
PORT=3001
LOG_LEVEL=info
COOKIE_SECRET=change-me-to-a-long-random-string
SESSION_TTL_HOURS=24
DATABASE_URL=postgresql://launchpad:launchpad@localhost:5432/claw_launchpad?schema=public
DIGITALOCEAN_CLIENT_ID=your-digitalocean-client-id
DIGITALOCEAN_CLIENT_SECRET=your-digitalocean-client-secret
DIGITALOCEAN_REDIRECT_URI=http://localhost:3001/api/v1/auth/digitalocean/callback
LAUNCHPAD_PUBLIC_API_URL=http://localhost:3001
LAUNCHPAD_WEB_URL=http://localhost:3000
DIGITALOCEAN_OAUTH_SCOPES=droplet:create droplet:read regions:read sizes:read actions:read image:read
WORKER_POLL_INTERVAL_MS=10000
